#!/usr/bin/env bash

# Copyright Elasticsearch B.V. and/or licensed to Elasticsearch B.V. under one
# or more contributor license agreements. Licensed under the Elastic License 2.0.

set -euo pipefail

log_name=esdiag-control
command_name=${0##*/}
repository_root=$(pwd -P)
runtime=""
push=false
open_browser=true

info() { printf '[Info %s] %s\n' "$log_name" "$*" >&2; }
die() { printf '[Error %s] %s\n' "$log_name" "$*" >&2; exit 1; }
have() { command -v "$1" >/dev/null 2>&1; }

version() { sed -n 's/^version = "\([^"]*\)"/\1/p' Cargo.toml | head -n 1; }

usage() {
    cat <<EOF
ESDiag repository build and local-stack control

Usage: ${command_name} <command> [options]

Commands:
  build    Build ESDiag for the current platform
  buildx   Build ESDiag for linux/amd64 and linux/arm64
  up       Build and start through bin/esdiag-local
  down     Stop the delegated local stack
  setup    Re-run delegated asset setup
  auth     Check delegated stack authentication
  help     Show this help

Options:
  --runtime podman|docker
  --registry URL
  --push
  --open-browser=true|false
  --state-dir DIR
EOF
}

validate_repository() {
    [[ -f Cargo.toml && -f docker/Dockerfile && -x bin/esdiag-local ]] || \
        die "Run this command from the ESDiag repository root"
    [[ $(id -u) -ne 0 ]] || die "Running as root is not supported"
}

detect_runtime() {
    if [[ -z "$runtime" ]]; then
        if have podman; then runtime=podman
        elif have docker; then runtime=docker
        else die "Podman or Docker is required"
        fi
    fi
    [[ "$runtime" == podman || "$runtime" == docker ]] || die "Runtime must be podman or docker"
    have "$runtime" || die "Runtime not found: ${runtime}"
}

image_names() {
    local release="$1" registry="${ESDIAG_REGISTRY:-}"
    registry=${registry%/}
    if [[ -n "$registry" ]]; then
        image="${registry}/esdiag/esdiag:${release}"
        latest_image="${registry}/esdiag/esdiag:latest"
    else
        image="esdiag:${release}"
        latest_image="esdiag:latest"
    fi
}

command_build() {
    local release image latest_image
    release=$(version); image_names "$release"
    if "$runtime" image inspect "$image" >/dev/null 2>&1; then info "Using existing ${image}"; return; fi
    args=(build --file docker/Dockerfile . --tag "$latest_image" --tag "$image")
    [[ "$push" == true ]] && args+=(--push)
    "$runtime" "${args[@]}"
}

command_buildx() {
    local release image latest_image
    release=$(version); image_names "$release"
    args=(buildx build --file docker/Dockerfile . --platform "linux/amd64,linux/arm64" --tag "$latest_image" --tag "$image")
    [[ "$push" == true ]] && args+=(--push)
    "$runtime" "${args[@]}"
}

delegate() {
    local subcommand="$1" release state
    release=$(version)
    state=${ESDIAG_LOCAL_DIR:-${repository_root}/target/esdiag-local}
    args=("$subcommand" --state-dir "$state" --runtime "$runtime" --pull never --open-browser="$open_browser")
    ESDIAG_IMAGE_TAG="esdiag:${release}" exec "${repository_root}/bin/esdiag-local" "${args[@]}"
}

validate_repository
command=${1:-help}; [[ $# -eq 0 ]] || shift
while [[ $# -gt 0 ]]; do
    case "$1" in
        --runtime) [[ $# -ge 2 ]] || die "Missing --runtime value"; runtime=$2; shift 2 ;;
        --runtime=*) runtime=${1#*=}; shift ;;
        --registry) [[ $# -ge 2 ]] || die "Missing --registry value"; ESDIAG_REGISTRY=$2; export ESDIAG_REGISTRY; shift 2 ;;
        --registry=*) ESDIAG_REGISTRY=${1#*=}; export ESDIAG_REGISTRY; shift ;;
        --state-dir) [[ $# -ge 2 ]] || die "Missing --state-dir value"; ESDIAG_LOCAL_DIR=$2; export ESDIAG_LOCAL_DIR; shift 2 ;;
        --state-dir=*) ESDIAG_LOCAL_DIR=${1#*=}; export ESDIAG_LOCAL_DIR; shift ;;
        --push) push=true; shift ;;
        --open-browser=*) open_browser=${1#*=}; shift ;;
        -b) [[ $# -ge 2 ]] || die "Missing -b value"; open_browser=$2; shift 2 ;;
        -e|--env) [[ $# -ge 2 ]] || die "Missing --env value"; shift 2 ;;
        -s|--space) [[ $# -ge 2 ]] || die "Missing --space value"; ESDIAG_KIBANA_SPACE=$2; export ESDIAG_KIBANA_SPACE; shift 2 ;;
        -h|--help) command=help; shift ;;
        *) die "Unknown option: $1" ;;
    esac
done
[[ "$open_browser" == true || "$open_browser" == false ]] || die "--open-browser must be true or false"

case "$command" in
    help|-h|--help) usage ;;
    build) detect_runtime; command_build ;;
    buildx) detect_runtime; command_buildx ;;
    up) detect_runtime; command_build; delegate up ;;
    down|setup|auth) detect_runtime; delegate "$command" ;;
    --version) version ;;
    *) die "Unknown command: ${command}" ;;
esac
