{
  "identifier": "com.elastic.esdiag",
  "build": {
    "frontendDist": "frontend-dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "ESDiag",
        "width": 1200,
        "height": 800,
        "dragDropEnabled": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg",
      "msi"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "opener": {}
  }
}
