{
  "identifier": "com.elastic.esdiag",
  "build": {
    "frontendDist": "desktop/frontend-dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "ESDiag",
        "width": 1200,
        "height": 800,
        "dragDropEnabled": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "msi"],
    "windows": {
      "wix": {
        "bannerPath": "desktop/packaging/windows/msi-banner.bmp",
        "dialogImagePath": "desktop/packaging/windows/msi-dialog.bmp"
      }
    },
    "icon": [
      "desktop/icons/32x32.png",
      "desktop/icons/128x128.png",
      "desktop/icons/128x128@2x.png",
      "desktop/icons/icon.icns",
      "desktop/icons/icon.ico"
    ]
  },
  "plugins": {
    "opener": {}
  }
}
