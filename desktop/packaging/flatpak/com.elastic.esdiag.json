{
  "app-id": "com.elastic.esdiag",
  "runtime": "org.gnome.Platform",
  "runtime-version": "49",
  "sdk": "org.gnome.Sdk",
  "sdk-extensions": ["org.freedesktop.Sdk.Extension.rust-stable"],
  "build-options": {
    "append-path": "/usr/lib/sdk/rust-stable/bin:/app/bin",
    "build-args": ["--share=network"]
  },
  "command": "esdiag",
  "branch": "stable",
  "x-esdiag-base-app-version": "0.15.0",
  "finish-args": [
    "--share=network",
    "--socket=x11",
    "--socket=wayland",
    "--env=WEBKIT_DISABLE_DMABUF_RENDERER=1",
    "--device=dri",
    "--filesystem=home"
  ],
  "modules": [
    {
      "name": "esdiag",
      "buildsystem": "simple",
      "build-commands": [
        "ESDIAG_GENERATE_NOTICE=0 cargo build --release --features desktop --locked",
        "install -Dm755 target/release/esdiag /app/bin/esdiag"
      ],
      "sources": [
        {
          "type": "dir",
          "path": "../../.."
        }
      ]
    }
  ]
}
