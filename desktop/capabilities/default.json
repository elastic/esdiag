{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "webviews": [
    "main"
  ],
  "local": false,
  "remote": {
    "urls": [
      "http://localhost:*",
      "http://127.0.0.1:*"
    ]
  },
  "permissions": [
    "core:window:allow-set-theme",
    "opener:default",
    "opener:allow-open-url"
  ]
}
