{
  "_meta": {
    "description": "ESDiag default index settings"
  },
  "template": {
    "lifecycle": {
      "data_retention": "30d"
    },
    "settings": {
      "index": {
        "codec": "best_compression",
        "lifecycle": {
          "prefer_ilm": false,
          "name": "metrics"
        },
        "mapping": {
          "total_fields": {
            "ignore_dynamic_beyond_limit": "true"
          },
          "source": {
            "mode": "synthetic"
          }
        },
        "query": {
          "default_field": ["*.name"]
        }
      }
    }
  },
  "version": 2
}
