{
  "_meta": {
    "managed": false,
    "description": "ESDiag Elastic Agent metadata mappings"
  },
  "template": {
    "mappings": {
      "dynamic_date_formats": [
        "strict_date_optional_time",
        "yyyy/MM/dd HH:mm:ss Z||yyyy/MM/dd Z"
      ],
      "properties": {
        "agent": {
          "type": "object",
          "properties": {
            "id": {
              "type": "keyword",
              "ignore_above": 1024
            },
            "version": {
              "type": "keyword",
              "ignore_above": 256
            },
            "snapshot": {
              "type": "boolean"
            },
            "unprivileged": {
              "type": "boolean"
            }
          }
        },
        "host": {
          "type": "object",
          "properties": {
            "hostname": {
              "type": "keyword",
              "ignore_above": 1024
            },
            "name": {
              "type": "keyword",
              "ignore_above": 1024
            },
            "arch": {
              "type": "keyword",
              "ignore_above": 256
            },
            "ip": {
              "type": "keyword"
            }
          }
        },
        "os": {
          "type": "object",
          "properties": {
            "family": {
              "type": "keyword",
              "ignore_above": 256
            },
            "name": {
              "type": "keyword",
              "ignore_above": 256
            },
            "platform": {
              "type": "keyword",
              "ignore_above": 256
            },
            "version": {
              "type": "keyword",
              "ignore_above": 256
            },
            "kernel": {
              "type": "keyword",
              "ignore_above": 256
            }
          }
        },
        "diagnostic": {
          "type": "object",
          "properties": {
            "id": {
              "type": "keyword",
              "ignore_above": 1024
            },
            "uuid": {
              "type": "keyword",
              "ignore_above": 1024
            },
            "collection_date": {
              "type": "date",
              "format": "strict_date_optional_time||epoch_millis"
            },
            "product": {
              "type": "keyword",
              "ignore_above": 256
            }
          }
        },
        "event": {
          "type": "object",
          "properties": {
            "ingested": {
              "type": "date"
            }
          }
        }
      }
    }
  },
  "version": 1
}
