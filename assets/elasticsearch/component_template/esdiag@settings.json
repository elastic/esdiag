{
  "version": 1,
  "template": {
    "lifecycle": {
      "data_retention": "15d"
    },
    "settings": {
      "index": {
        "codec": "best_compression",
        "lifecycle": {
          "prefer_ilm": false,
          "name": "metrics"
        },
        "mapping": {
          "total_fields": {
            "ignore_dynamic_beyond_limit": "true"
          },
          "source": {
            "mode": "synthetic"
          }
        },
        "query": {
          "default_field": ["*.name"]
        }
      }
    }
  },
  "_meta": {
    "managed": false,
    "description": "Default settings for the esdiag index templates"
  }
}
