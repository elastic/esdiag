{
    "template": {
        "mappings": {
            "dynamic_date_formats": [
                "strict_date_optional_time",
                "yyyy/MM/dd HH:mm:ss Z||yyyy/MM/dd Z"
            ],
            "properties": {
                "cluster": {
                    "type": "object",
                    "properties": {
                        "name": {
                            "type": "keyword"
                        },
                        "uuid": {
                            "type": "keyword"
                        },
                        "tagline": {
                            "type": "object",
                            "enabled": false
                        }
                    }
                },
                "diagnostic": {
                    "type": "object",
                    "properties": {
                        "node": {
                            "ignore_above": 1024,
                            "type": "keyword"
                        },
                        "inputs": {
                            "type": "match_only_text"
                        },
                        "runner": {
                            "ignore_above": 1024,
                            "type": "keyword"
                        },
                        "collection_date": {
                            "format": "strict_date_optional_time||epoch_millis",
                            "index": true,
                            "ignore_malformed": false,
                            "store": false,
                            "type": "date",
                            "doc_values": true
                        },
                        "uuid": {
                            "ignore_above": 1024,
                            "type": "keyword"
                        }
                    }
                }
            }
        }
    },
    "_meta": {
        "managed": false,
        "description": "Common mappings for the esdiag metadata"
    }
}