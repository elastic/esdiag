{
  "_meta": {
    "description": "ESDiag Elasticsearch node HTTP client stats"
  },
  "index_patterns": ["metrics-node.http.clients-esdiag*"],
  "composed_of": [
    "esdiag@mappings",
    "esdiag@metadata",
    "esdiag@settings",
    "esdiag@node"
  ],
  "allow_auto_create": true,
  "data_stream": {
    "hidden": false,
    "allow_custom_routing": false
  },
  "priority": 310,
  "template": {
    "mappings": {
      "properties": {
        "data_stream": {
          "type": "object",
          "properties": {
            "dataset": {
              "type": "constant_keyword",
              "value": "node.http.clients"
            },
            "type": {
              "type": "constant_keyword",
              "value": "metrics"
            }
          }
        },
        "http": {
          "properties": {
            "client": {
              "type": "object",
              "enabled": false
            }
          }
        }
      }
    }
  },
  "version": 2
}
