{
  "_meta": {
    "description": "ESDiag Elasticsearch health report diagnosis"
  },
  "index_patterns": ["health-diagnosis-esdiag*"],
  "composed_of": [
    "esdiag@node",
    "esdiag@mappings",
    "esdiag@metadata",
    "esdiag@settings"
  ],
  "allow_auto_create": true,
  "data_stream": {},
  "priority": 300,
  "template": {
    "mappings": {
      "numeric_detection": false,
      "dynamic": true,
      "dynamic_templates": [
        {
          "strings_as_keywords": {
            "mapping": {
              "type": "keyword"
            },
            "match_mapping_type": "string"
          }
        }
      ],
      "properties": {
        "data_stream": {
          "type": "object",
          "properties": {
            "dataset": {
              "type": "constant_keyword",
              "value": "diagnosis"
            },
            "type": {
              "type": "constant_keyword",
              "value": "health"
            }
          }
        }
      }
    }
  }
}
