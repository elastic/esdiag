{
  "_meta": {
    "description": "ESDiag Elasticsearch ingest processor stats"
  },
  "index_patterns": ["metrics-ingest.processor-esdiag*"],
  "composed_of": [
    "esdiag@mappings",
    "esdiag@metadata",
    "esdiag@settings",
    "esdiag@node"
  ],
  "allow_auto_create": true,
  "data_stream": {
    "hidden": false,
    "allow_custom_routing": false
  },
  "priority": 300,
  "template": {
    "mappings": {
      "numeric_detection": false,
      "dynamic": true,
      "properties": {
        "data_stream": {
          "type": "object",
          "properties": {
            "dataset": {
              "type": "constant_keyword",
              "value": "ingest.processor"
            }
          }
        },
        "ingest": {
          "properties": {
            "pipeline": {
              "properties": {
                "name": {
                  "type": "keyword"
                }
              }
            },
            "processor": {
              "properties": {
                "count": {
                  "type": "long",
                  "index": false
                },
                "current": {
                  "type": "long",
                  "index": false
                },
                "failed": {
                  "type": "long",
                  "index": false
                },
                "name": {
                  "type": "keyword"
                },
                "order": {
                  "type": "long",
                  "index": false
                },
                "time_in_millis": {
                  "type": "long",
                  "index": false
                },
                "type": {
                  "type": "keyword"
                }
              }
            }
          }
        }
      }
    }
  },
  "version": 2
}
