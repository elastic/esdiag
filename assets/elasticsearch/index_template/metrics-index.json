{
  "index_patterns": ["metrics-index-esdiag*"],
  "composed_of": [
    "esdiag@metadata",
    "esdiag@mappings",
    "esdiag@settings",
    "esdiag@ilm",
    "esdiag@index"
  ],
  "allow_auto_create": true,
  "data_stream": {
    "hidden": false,
    "allow_custom_routing": false
  },
  "priority": 300,
  "template": {
    "mappings": {
      "numeric_detection": false,
      "dynamic": true,
      "properties": {
        "data_stream": {
          "type": "object",
          "properties": {
            "dataset": {
              "type": "constant_keyword",
              "value": "index"
            }
          }
        },
        "diagnostic.uuid": {
          "type": "keyword"
        },
        "retention_leases.leases": {
          "eager_global_ordinals": false,
          "index": true,
          "type": "flattened",
          "split_queries_on_whitespace": false,
          "index_options": "docs",
          "doc_values": true
        }
      }
    }
  }
}
