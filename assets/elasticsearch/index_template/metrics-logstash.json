{
  "index_patterns": ["settings-logstash*-esdiag*"],
  "composed_of": [
    "esdiag@ls-mappings",
    "esdiag@ls-metadata",
    "esdiag@settings"
  ],
  "allow_auto_create": true,
  "data_stream": {
    "hidden": false,
    "allow_custom_routing": false
  },
  "priority": 300,
  "template": {
    "mappings": {
      "numeric_detection": false,
      "dynamic": true,
      "dynamic_templates": [
        {
          "strings_as_keywords": {
            "mapping": {
              "type": "keyword"
            },
            "match_mapping_type": "string"
          }
        }
      ],
      "properties": {
        "data_stream": {
          "type": "object",
          "properties": {
            "dataset": {
              "type": "constant_keyword"
            },
            "type": {
              "type": "constant_keyword",
              "value": "settings"
            }
          }
        }
      }
    }
  }
}
