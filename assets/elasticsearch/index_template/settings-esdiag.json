{
    "index_patterns": [
        "settings-*-esdiag*"
    ],
    "composed_of": [
        "esdiag@mappings",
        "esdiag@metadata",
        "esdiag@settings"
    ],
    "allow_auto_create": true,
    "data_stream": {
        "hidden": false,
        "allow_custom_routing": false
    },
    "priority": 290,
    "template": {
        "mappings": {
            "_routing": {
                "required": false
            },
            "date_detection": true,
            "numeric_detection": false,
            "dynamic_date_formats": [
                "strict_date_optional_time",
                "yyyy/MM/dd HH:mm:ss Z||yyyy/MM/dd Z"
            ],
            "dynamic": true,
            "properties": {
                "data_stream": {
                    "type": "object",
                    "properties": {
                        "type": {
                            "type": "constant_keyword",
                            "value": "settings"
                        }
                    }
                }
            }
        }
    },
    "_meta": {
        "description": "Settings or esdiag data streams"
    }
}