{
  "index_patterns": ["metrics-task-esdiag*"],
  "composed_of": ["esdiag@mappings", "esdiag@metadata", "esdiag@settings"],
  "allow_auto_create": true,
  "data_stream": {
    "hidden": false,
    "allow_custom_routing": false
  },
  "priority": 300,
  "template": {
    "mappings": {
      "numeric_detection": false,
      "dynamic": true,
      "dynamic_templates": [
        {
          "strings_as_keywords": {
            "mapping": {
              "type": "keyword"
            },
            "match_mapping_type": "string"
          }
        }
      ],
      "properties": {
        "data_stream": {
          "type": "object",
          "properties": {
            "dataset": {
              "type": "constant_keyword",
              "value": "task"
            }
          }
        },
        "task": {
          "type": "object",
          "properties": {
            "description": {
              "type": "match_only_text"
            },
            "id": {
              "type": "keyword"
            },
            "parent.id": {
              "type": "keyword"
            },
            "node.ip": {
              "type": "ip"
            },
            "parent_task_id": {
              "type": "object",
              "enabled": false
            },
            "running_time": {
              "type": "object",
              "enabled": false
            },
            "start_time": {
              "type": "object",
              "enabled": false
            },
            "start_time_in_millis": {
              "type": "date"
            },
            "status.total_download_time": {
              "type": "long"
            },
            "status.active_operators.operator": {
              "type": "match_only_text"
            }
          }
        }
      }
    }
  }
}
