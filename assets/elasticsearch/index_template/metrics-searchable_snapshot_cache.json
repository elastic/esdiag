{
    "index_patterns": [
        "metrics-searchable_snapshot_cache-esdiag*"
    ],
    "composed_of": [
        "esdiag@mappings",
        "esdiag@metadata",
        "esdiag@settings"
    ],
    "allow_auto_create": true,
    "data_stream": {
        "hidden": false,
        "allow_custom_routing": false
    },
    "priority": 300,
    "template": {
        "mappings": {
            "dynamic": true,
            "properties": {
                "data_stream": {
                    "type": "object",
                    "properties": {
                        "dataset": {
                            "type": "constant_keyword",
                            "value": "searchable_snapshot_cache"
                        }
                    }
                },
                "shared_cache": {
                    "type": "object",
                    "properties": {
                        "reads": {
                            "type": "long"
                        },
                        "bytes_read": {
                            "type": "object",
                            "enabled": false
                        },
                        "bytes_read_in_bytes": {
                            "type": "long"
                        },
                        "writes": {
                            "type": "long"
                        },
                        "bytes_written": {
                            "type": "object",
                            "enabled": false
                        },
                        "bytes_written_in_bytes": {
                            "type": "long"
                        },
                        "evictions": {
                            "type": "long"
                        },
                        "num_regions": {
                            "type": "long"
                        },
                        "size": {
                            "type": "object",
                            "enabled": false
                        },
                        "size_in_bytes": {
                            "type": "long"
                        },
                        "region_size": {
                            "type": "object",
                            "enabled": false
                        },
                        "region_size_in_bytes": {
                            "type": "long"
                        }
                    }
                }
            }
        }
    }
}