{
  "description": "Ingest pipeline for documents shipped from the Elastic Stack Diagnostics tool (ESDiag)",
  "processors": [
    {
      "set": {
        "ignore_failure": true,
        "field": "event.ingested",
        "value": "{{_ingest.timestamp}}"
      }
    },
    {
      "set": {
        "ignore_failure": true,
        "if": "ctx?.diagnostic?.account == null",
        "field": "diagnostic.account",
        "value": "{{diagnostic.license.issued_to}}"
      }
    },
    {
      "reroute": {}
    }
  ]
}
