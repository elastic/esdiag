        "embeddableConfig": {
          "description": "The percentage of used heap memory. When using Garbage-First Garbage Collector (G1GC) consistently operating around 80% is expected. Sustained values over 90% is an indicator of high memory pressure.",
          "enhancements": {
            "dynamicActions": {
              "events": []
            }
          },
          "savedVis": {
            "data": {
              "aggs": [],
              "searchSource": {
                "filter": [],
                "query": {
